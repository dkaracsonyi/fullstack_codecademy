function getSleepHours(day){
  switch (day){
  case "monday":
    return 6;
  case "tuesday":
    return 7;
  case "wednesday":
    return 5;
  case "thursday":
    return 6;
  case "friday":
    return 6;
  case "saturday":
    return 8;
  case "sunday":
    return 8;
  default:
  return;
}

}
console.log(getSleepHours("monday"));

const getActualSleepHours = () => 
  getSleepHours('monday') +
  getSleepHours('tuesday') +
  getSleepHours('wednesday') +
  getSleepHours('thursday') +
  getSleepHours('friday') +
  getSleepHours('saturday') +
  getSleepHours('sunday');


function getIdealSleepHours(hour){
  return hour*7;
}

function calculateSleepDebt(){
  const actualSleepHours = getActualSleepHours();
  const idealSleepHours = getIdealSleepHours(7);

  if (actualSleepHours === idealSleepHours){
    console.log("You already got the perfect amount of sleep.");
    }
  else if (actualSleepHours > idealSleepHours){
    console.log("You are well rested! You got more sleep than needed. You slept for " + (actualSleepHours-idealSleepHours) + " hours more than needed.");
  }
  else {
    console.log("You should get more rest. You slept for " + (idealSleepHours-actualSleepHours) + " hours less than required.");
  }
}

calculateSleepDebt();